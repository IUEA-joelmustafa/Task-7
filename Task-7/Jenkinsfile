pipeline {

    agent { label 'java-build-agent' }

    environment {
        APP_NAME       = 'Task-7'
        SONAR_HOST_URL = 'http://localhost:9000'
        SONAR_TOKEN    = credentials('sonarqube-token')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out code from GitHub...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo 'Compiling Smart Student Manager...'
                bat 'cd Task-7 && mvn clean compile -B'
            }
        }

        stage('Unit Tests') {
            steps {
                echo 'Running JUnit tests...'
                bat 'cd Task-7 && mvn test -B'
            }
            post {
                always {
                    junit 'Task-7/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Code Quality - SonarQube') {
            steps {
                echo 'Running SonarQube analysis...'
                bat "cd Task-7 && mvn sonar:sonar -Dsonar.projectKey=%APP_NAME% -Dsonar.host.url=%SONAR_HOST_URL% -Dsonar.login=%SONAR_TOKEN% -B"
            }
            post {
                success {
                    echo 'SonarQube analysis complete!'
                }
            }
        }

        stage('Package') {
            steps {
                echo 'Packaging into JAR...'
                bat 'cd Task-7 && mvn package -DskipTests -B'
            }
            post {
                success {
                    archiveArtifacts artifacts: 'Task-7/target/*.jar',
                                     fingerprint: true
                }
            }
        }

    }

    post {
        always {
            echo "Pipeline finished. Status: ${currentBuild.currentResult}"
        }
        success {
            echo "BUILD PASSED - ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
        failure {
            echo "BUILD FAILED - ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
    }
}